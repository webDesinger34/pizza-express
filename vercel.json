{
  "version": 2,
  "functions": {
    "api/orders.js": {
      "runtime": "@vercel/node@3"
    }
  },
  "routes": [
    { "src": "/api/orders", "dest": "/api/orders.js" },
    { "src": "/admin", "dest": "/admin.html" },
    { "src": "/kueche", "dest": "/kueche.html" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
